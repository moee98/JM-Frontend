# Copy this file to .env and fill in the values.
# NEVER commit .env to source control.

# ── Path to the backend project ───────────────────────────────────────────────
# Absolute path to the OrderManagementAPI project folder on your machine.
BACKEND_PATH=C:\Users\mebrahim\source\repos\OrderManagementAPI

# ── SQL Server ────────────────────────────────────────────────────────────────
# Must meet SQL Server password complexity rules:
#   8+ characters, uppercase, lowercase, digit, and a special character.
MSSQL_SA_PASSWORD=YourStrong@Passw0rd

# ── JWT ───────────────────────────────────────────────────────────────────────
# Minimum 32 random characters. Use the same key across restarts or all
# existing sessions will be invalidated.
JWT_KEY=replace-this-with-a-random-32-char-minimum-secret

# ── SMTP (optional — for Send Invoice emails) ─────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=you@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=you@gmail.com
